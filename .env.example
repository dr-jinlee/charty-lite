# Claude API 키 (차트 변환용 - 유일한 외부 API)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 서버 포트
BACKEND_PORT=8080
FRONTEND_PORT=3000
AI_PORT=8081

# Whisper 설정
WHISPER_MODEL=large-v3
# GPU 없으면 cpu, 있으면 cuda
WHISPER_DEVICE=cpu

# 화자 분리 (pyannote)
# https://huggingface.co/pyannote/speaker-diarization-3.1 에서 토큰 발급
HF_AUTH_TOKEN=hf_xxxxx

# 프론트엔드 API URL (배포 시 변경)
# frontend/.env.local에 설정
NEXT_PUBLIC_API_URL=http://localhost:8081

# 데이터 저장 경로
DATA_DIR=./data
DB_PATH=./data/voice-to-chart.db
RECORDINGS_DIR=./data/recordings
